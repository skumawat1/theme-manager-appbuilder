{
    "env": {
        "es6": true,
        "node": true
    },
    "extends": ["eslint:recommended", "plugin:jest/recommended"],
    "parserOptions": {
        "ecmaVersion": "latest"
    },
    "overrides": [
        {
            "files": ["web-src/**/*.js"],
            "parserOptions": {
                "ecmaVersion": "latest",
                "sourceType": "module",
                "ecmaFeatures": {
                    "importAssertions": true
                }
            },
            "env": {
                "browser": true,
                "node": false
            }
        }
    ]
}
